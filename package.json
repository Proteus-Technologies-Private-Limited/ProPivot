{
  "name": "@proteus/propivot",
  "version": "0.3.1",
  "description": "ProPivot — an enterprise-grade, open-source JavaScript library for building pivot tables over millions of rows. Works with React, Angular, Vue, and any framework (or plain JavaScript via a script tag). Lightning fast, lightweight, feature-rich, highly configurable, and instantly embedded in any project. 100% client-side: 17 aggregations, calculated measures, conditional formatting, virtualized rendering, and five export formats.",
  "license": "MIT",
  "author": "Proteus Technologies Private Limited",
  "homepage": "https://proteus-technologies-private-limited.github.io/ProPivot/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Proteus-Technologies-Private-Limited/ProPivot.git"
  },
  "bugs": {
    "url": "https://github.com/Proteus-Technologies-Private-Limited/ProPivot/issues"
  },
  "keywords": [
    "pivot",
    "pivot-table",
    "pivot-grid",
    "data-grid",
    "aggregation",
    "olap",
    "analytics",
    "angular",
    "react",
    "vue",
    "javascript",
    "typescript",
    "vanilla-js",
    "client-side"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./angular": {
      "types": "./src/wrappers/angular.ts",
      "default": "./src/wrappers/angular.ts"
    },
    "./global": "./dist/propivot.global.js",
    "./propivot.css": "./dist/propivot.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run test/golden",
    "golden:update": "UPDATE_GOLDENS=1 vitest run test/golden",
    "check:version": "node test-script/check-version.mjs",
    "check:angular": "tsc -p test-script/angular-typecheck/tsconfig.json",
    "ci": "npm run check:version && npm run typecheck && npm run check:angular && npm run test && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "duckdb-async": "^1.4.2",
    "happy-dom": "^20.10.6",
    "react": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "@angular/common": ">=15",
    "@angular/core": ">=15",
    "react": ">=17",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
